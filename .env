# Database - Using SQLite for local development
# For production, use PostgreSQL:
# DATABASE_URL="postgresql://user:password@host:5432/pretty_party_sweets?schema=public"
DATABASE_URL="file:./dev.db"

# NextAuth - Generate a secure secret for production
# Run: openssl rand -base64 32
NEXTAUTH_SECRET="development-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Site URL - Update for production
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Email (Resend) - Add your API key when ready
RESEND_API_KEY="re_xxxxxxxxxxxxx"
EMAIL_FROM="noreply@localhost"

# Upload - Add credentials when ready
UPLOADTHING_SECRET="sk_xxxxxxxxxxxxx"
UPLOADTHING_APP_ID="app_xxxxxxxxxxxxx"

# Admin Credentials - CHANGE THESE FOR PRODUCTION!
# Step 1: Set your admin email
ADMIN_EMAIL="admin@prettypartysweets.com"

# Step 2: Set a secure password
ADMIN_PASSWORD="your_secure_password_here"

# Step 3: Generate hash (run: npx ts-node scripts/generate-password-hash.ts <password>)
# Step 4: Copy the hash below and REMOVE the ADMIN_PASSWORD line
# ADMIN_PASSWORD_HASH="$2a$12$..."

# SECURITY NOTES:
# - Never commit .env to Git
# - Use strong password (12+ chars, mixed case, numbers, symbols)
# - Remove ADMIN_PASSWORD after generating hash
# - Keep ADMIN_PASSWORD_HASH only
